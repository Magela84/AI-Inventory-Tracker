# Frontend environment (copy to frontend/.env). All optional.

# Backend API base URL (default http://localhost:3001/api)
VITE_API_BASE_URL=

# If the backend has API_KEY set, put the same value here.
VITE_API_KEY=

# Enable "Sign in with Google": use the SAME OAuth client ID as the backend's
# GOOGLE_CLIENT_ID. Leave blank to hide the Google button.
VITE_GOOGLE_CLIENT_ID=
