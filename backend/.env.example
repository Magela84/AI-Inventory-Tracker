AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=inventory-db
AZURE_COSMOS_CONTAINER=products
AZURE_COSMOS_USERS_CONTAINER=users
AZURE_COSMOS_SUPPLIERS_CONTAINER=suppliers
AZURE_COSMOS_PURCHASE_ORDERS_CONTAINER=purchaseOrders
AZURE_COSMOS_MOVEMENTS_CONTAINER=movements
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_ANOMALY_DETECTOR_ENDPOINT=
AZURE_ANOMALY_DETECTOR_KEY=
MOCK_DATA=true
PORT=3001
# Secret used to sign user JWTs. Change this to a long random string in production.
JWT_SECRET=dev-secret-change-me
# Google OAuth: set to enable "Sign in with Google". Get a client ID from
# https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, Web).
# The SAME value must be set as VITE_GOOGLE_CLIENT_ID in frontend/.env.
GOOGLE_CLIENT_ID=
# Comma-separated emails that get the admin role on first signup (local or Google).
ADMIN_EMAILS=
# Optional: when set, all /api routes (except /api/health) require a matching
# x-api-key header (in addition to the user token). Leave blank to disable.
API_KEY=
